{
  "name": "whistle.mockya",
  "version": "0.0.1-alpha.5",
  "description": "A simple whistle-based mock plugin with ui for http/rpc endpoints",
  "scripts": {
    "postinstall": "npx prisma generate && DATABASE_URL=\"file:./mockya.db\" npx prisma migrate deploy",
    "build": "tsc -b && tsc-alias",
    "dev:ts": "tsc -w",
    "dev:ts-alias": "tsc-alias -w",
    "dev:whistle": "w2 stop && w2 run",
    "dev:lack": "lack watch",
    "dev": "run-p dev:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aijun-li/whistle.mockya"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "whistle",
    "plugin",
    "mock"
  ],
  "engines": {
    "node": ">=16",
    "pnpm": ">=7"
  },
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "devDependencies": {
    "@types/koa": "^2.13.4",
    "@types/koa-bodyparser": "^4.3.5",
    "@types/koa-router": "^7.4.4",
    "@types/koa-static": "^4.0.2",
    "@types/koa__cors": "^3.3.0",
    "@types/node": "^18.11.0",
    "@typescript-eslint/eslint-plugin": "^5.38.0",
    "@typescript-eslint/parser": "^5.38.0",
    "eslint": "^8.23.1",
    "eslint-config-prettier": "^8.5.0",
    "lack": "^1.3.8",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.7.0",
    "typescript": "^4.6.2"
  },
  "dependencies": {
    "@koa/cors": "^4.0.0",
    "@prisma/client": "^4.4.0",
    "koa": "^2.7.0",
    "koa-bodyparser": "^4.2.1",
    "koa-onerror": "^4.1.0",
    "koa-router": "^7.4.0",
    "koa-static": "^5.0.0",
    "prisma": "^4.4.0"
  }
}
